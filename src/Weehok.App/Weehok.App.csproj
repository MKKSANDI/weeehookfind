<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>Weehok</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="logo.png" />
  </ItemGroup>

  <Target Name="BuildRustScanner" BeforeTargets="Build">
    <PropertyGroup>
      <ScannerManifest>$(MSBuildThisFileDirectory)..\weehok-scanner\Cargo.toml</ScannerManifest>
      <ScannerExe>$(MSBuildThisFileDirectory)..\weehok-scanner\target\release\weehok-scanner.exe</ScannerExe>
    </PropertyGroup>
    <Exec Command="cargo build --release --manifest-path &quot;$(ScannerManifest)&quot;" />
    <Copy SourceFiles="$(ScannerExe)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
